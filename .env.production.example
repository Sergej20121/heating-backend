NODE_ENV=production
PORT=3000

# В production здесь должен быть реальный PostgreSQL на сервере, не localhost.
DATABASE_URL="postgresql://heating_user:STRONG_DB_PASSWORD@db.your-real-domain.ru:5432/heating_app?schema=public"

# Минимум 32 случайных символа. Сгенерируй свой секрет и не публикуй его.
JWT_SECRET="REPLACE_WITH_REAL_RANDOM_SECRET_32_PLUS_CHARS"
JWT_EXPIRES_IN="7d"

# SMS_DEBUG_TO_CONSOLE в production всегда false.
SMS_CODE_TTL_MINUTES=5
SMS_DEBUG_TO_CONSOLE=false
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_PER_HOUR=5
OTP_MAX_ATTEMPTS=5

READINGS_START_DAY=20
READINGS_END_DAY=25
ALLOW_READINGS_ANY_DAY=false

# Саморегистрация админа в production запрещена кодом.
ADMIN_REGISTRATION_ENABLED=false
ADMIN_REGISTRATION_CODE="DISABLED_IN_PRODUCTION"

# Только реальные HTTPS-домены админки/сайта через запятую.
CORS_ORIGINS=https://admin.your-real-domain.ru,https://your-real-domain.ru

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=180
RATE_LIMIT_AUTH_MAX_REQUESTS=20
RATE_LIMIT_CLEANUP_INTERVAL_MS=300000
NOTIFICATION_BATCH_SIZE=500
MAX_NOTIFICATION_HISTORY=200
ENABLE_MOCK_PAYMENTS=false
